# Coverage Manager exports path (local dev)
# In CI this is replaced by sparse-checkout of jroypeterson/Coverage-Manager
COVERAGE_MANAGER_PATH=C:/Users/jroyp/Dropbox/Claude Folder/Coverage Manager

# Anthropic — classification
ANTHROPIC_API_KEY=

# Tavily — web search per ticker
TAVILY_API_KEY=

# Slack — #analyst-days channel webhook (earnings_agent Slack app, new webhook URL bound to #analyst-days)
SLACK_WEBHOOK_ANALYST_DAYS=

# Google Calendar — same calendar earnings_agent writes to
GOOGLE_CALENDAR_ID=
GOOGLE_CREDENTIALS_PATH=credentials.json

# TickTick — token shared with earnings_agent; we auto-create / find an "Analyst Days" list
TICKTICK_ACCESS_TOKEN=

# Email — Gmail API via OAuth (reuses daily-reads' token; scopes include gmail.send).
# In CI, GMAIL_OAUTH_JSON holds the full token JSON content as a single env var.
# Locally, GMAIL_OAUTH_JSON_PATH points at the token file (avoids pasting 1KB JSON into a shell profile).
GMAIL_OAUTH_JSON_PATH=C:/Users/jroyp/Dropbox/API Keys/gmail_oauth_token.json
EMAIL_TO=jroypeterson@gmail.com

# EDGAR — required header
SEC_EDGAR_USER_AGENT=analyst-days (jroypeterson@gmail.com)

# Timezone — used for digest formatting
TIMEZONE=America/New_York

# Confidence threshold for auto-confirm (else tentative)
CONFIDENCE_THRESHOLD=0.80
